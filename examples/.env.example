# Copy to .env and fill in. NEVER commit the real .env.
SONIOX_API_KEY=sk-...                 # Soniox API key
INTERNAL_TOKEN=change-me-long-random  # shared secret the phone sends as x-internal-token (rotate after setup)
TELEGRAM_BOT_TOKEN=123456:ABC...      # bot used for failure alerts
CHAT_ID=00000000                      # your Telegram chat id
INBOX_QUEUE=/var/lib/secretary/inbox.jsonl
FAILED_DIR=/var/lib/secretary/failed
